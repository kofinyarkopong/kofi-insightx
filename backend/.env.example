# ── Backend environment variables ────────────────────────────────────────────
# Copy this file to .env for local development.
# In Vercel, set these under Project Settings → Environment Variables.

# Port used when running locally (Vercel ignores this)
PORT=3001

# Comma-separated list of allowed frontend origins.
# Set to your Vercel frontend URL in production, e.g.:
#   ALLOWED_ORIGINS=https://kofi-insightx.vercel.app
# Use * to allow all origins (convenient but not recommended for production).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: custom directory for the file-based cache (local development only)
CACHE_DIR=./cache

# Set to 'true' to run Playwright in headed (visible) mode locally for debugging
PLAYWRIGHT_HEADED=false

# ── Football-Data.org (optional — enables live league table enrichment) ────────
#
# Replaces the proxy motivation model with real league position, form, and
# points data from Football-Data.org.  Covers ~20 leagues on the free tier.
#
# Get a FREE key in 30 seconds at: https://www.football-data.org/client/register
# Supported leagues: Premier League, Bundesliga, La Liga, Serie A, Ligue 1,
#   Eredivisie, Primeira Liga, Championship, Champions League, MLS, and more.
#
# Without this key the dashboard still works — it uses the proxy motivation score.
FOOTBALL_DATA_API_KEY=your_free_api_key_here

# ── Supabase (required on Vercel; optional on Mac for live sync) ──────────────
#
# Without these vars:
#   Local mode works normally via file cache — no Supabase needed.
#
# With these vars on your Mac:
#   Every Playwright scrape also pushes results to Supabase automatically,
#   so your Vercel deployment always shows the latest data immediately.
#   You can also run `npm run scrape` as a standalone push command.
#
# On Vercel:
#   REQUIRED. The dashboard reads fixtures from Supabase (Playwright cannot
#   run on Vercel serverless). Add these in Vercel → Project Settings → Env Vars.
#
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
