# ── Frontend environment variables ───────────────────────────────────────────
# Copy this file to .env.local for local development.
# In Vercel, set these under Project Settings → Environment Variables.

# URL of the deployed backend API.
# Leave blank (or omit) for local development — Vite proxies /api to localhost:3001.
# In production set this to your backend Vercel deployment URL, e.g.:
#   VITE_API_URL=https://kofi-insightx-api.vercel.app
VITE_API_URL=
