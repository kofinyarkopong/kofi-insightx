{
  "name": "fpd-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":    "ts-node-dev --respawn --transpile-only src/server.ts",
    "build":  "tsc",
    "start":  "node dist/server.js",
    "test":   "jest --testPathPattern=tests/",
    "scrape": "ts-node --transpile-only -r dotenv/config src/scripts/scrape.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "cheerio":  "^1.0.0-rc.12",
    "cors":     "^2.8.5",
    "dotenv":   "^16.4.5",
    "express":  "^4.18.2",
    "playwright": "^1.44.1",
    "uuid":     "^9.0.1"
  },
  "devDependencies": {
    "@types/cheerio":  "^0.22.35",
    "@types/cors":     "^2.8.17",
    "@types/express":  "^4.17.21",
    "@types/jest":     "^29.5.12",
    "@types/node":     "^20.14.2",
    "@types/uuid":     "^9.0.8",
    "jest":            "^29.7.0",
    "ts-jest":         "^29.1.5",
    "ts-node":         "^10.9.2",
    "ts-node-dev":     "^2.0.0",
    "typescript":      "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"]
  }
}
