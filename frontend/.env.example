# ── Frontend environment variables ───────────────────────────────────────────
# Copy this file to .env.local for local development.
# In Vercel, set these under Project Settings → Environment Variables.

# ── Supabase (required) ───────────────────────────────────────────────────────
# Use the ANON / public key here (not the service role key).
# Find both at: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...YOUR-ANON-KEY

# ── Backend API (optional) ────────────────────────────────────────────────────
# Only needed for the manual paste route.
# Leave blank for local dev — Vite proxies /api to localhost:3001.
# In production set to your Vercel backend URL.
VITE_API_URL=
