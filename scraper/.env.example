# ── Supabase credentials ──────────────────────────────────────────────────────
# Use the SERVICE ROLE key here (not the anon key).
# The scraper needs full write access to bypass RLS.
# Find both keys at: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...YOUR-SERVICE-ROLE-KEY

# ── Scraper tuning (optional) ─────────────────────────────────────────────────
# How many ltodrows clicks before giving up (each click takes ~5.5 s)
MAX_CLICK_ATTEMPTS=80
# Milliseconds to wait after each ltodrows click
CLICK_WAIT_MS=5500
# Set to true to watch the browser window while scraping (useful for debugging)
PLAYWRIGHT_HEADED=false
